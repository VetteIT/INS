{
    "pythonVersion": "3.12",
    "typeCheckingMode": "basic",
    "reportMissingModuleSource": false,
    "reportMissingImports": false,
    "reportMissingTypeStubs": false,
    "reportUnusedImport": "warning",
    "reportUnusedVariable": "warning",
    "reportUnusedFunction": "warning",
    "exclude": [
        "data/",
        "**/__pycache__",
        "**/node_modules",
        "**/.*"
    ]
}
